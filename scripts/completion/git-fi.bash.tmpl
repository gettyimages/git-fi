# Branch completion is action-aware: --add offers origin branches not yet in
# fi, --remove offers only branches currently in fi, everything else offers all
# origin branches. fi membership comes from `git-fi --bare` with the network
# fetch suppressed (GIT_FI_NO_FETCH), so completion stays fast and offline.
#
# Helpers are nested inside _git_fi so the whole file is a single function
# definition. zsh's autoload (used for the completions/_git_fi copy) then runs
# the body on the first `git fi <TAB>` rather than only defining the function.
_git_fi () {
	__git_fi_remote_branches () {
		# Mirror git-fi's own filter: drop HEAD, the fi branch itself, and the
		# default branch (you don't add the base branch to fi). Resolve the
		# default the same way defaultBranch() does — origin/HEAD, else probe
		# main, master.
		local def c
		def=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null)
		def=${def#origin/}
		if [ -z "$def" ]; then
			for c in main master; do
				git rev-parse --verify --quiet "origin/$c" >/dev/null 2>&1 && { def=$c; break; }
			done
		fi
		git for-each-ref --format='%(refname:lstrip=3)' refs/remotes/origin 2>/dev/null \
			| grep -vxE "HEAD|fi|${def:-main}"
	}
	__git_fi_in_fi () {
		GIT_FI_NO_FETCH=1 git-fi --bare 2>/dev/null | tr ' ' '\n' | grep -v '^$'
	}

	# git sets $cur and the $words array in both bash and zsh (its zsh wrapper
	# runs under ksh emulation and does NOT populate COMP_WORDS), so read the
	# command line from $words when detecting the action flag.
	case "$cur" in
	-*)
		__gitcomp "@@LONG_FLAGS@@"
		return
		;;
	esac

	local action="" w
	for w in "${words[@]}"; do
		case "$w" in
		-a|--add) action="add" ;;
		-r|--remove) action="remove" ;;
		esac
	done

	case "$action" in
	remove)
		__gitcomp_nl "$(__git_fi_in_fi)"
		;;
	add)
		__gitcomp_nl "$(comm -23 <(__git_fi_remote_branches | sort) <(__git_fi_in_fi | sort))"
		;;
	*)
		# No action flag yet: offer the actions/options and subcommands, not a
		# branch dump. The branch argument completes once an action flag is
		# present (a bare positional is only a list-filter pattern).
		__gitcomp "@@LONG_FLAGS@@ help install-completions"
		;;
	esac
}
